# Image-generation provider for the art pipeline (scripts/providers.py).
# Default is fal.ai's gpt-image-2/edit.
CCPET_PROVIDER=fal

# fal.ai API key — https://fal.ai/dashboard/keys
FAL_KEY=your-fal-key-here

# If you implement the OpenAI provider stub instead:
# CCPET_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key-here

# Where the pipeline writes intermediate art (base sprite, row strips, atlas).
CCPET_WORKDIR=out
